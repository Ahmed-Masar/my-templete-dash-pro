{
  "info": {
    "name": "Wolf — Gym Equipment Management API",
    "_postman_id": "wolf-api-collection-v1",
    "description": "Complete API collection for Wolf Gym Equipment & Warehouse Management System.\n\nSetup:\n1. Set 'base_url' variable to your server URL\n2. Run 'Login' request first to auto-set tokens\n3. All other requests use the token automatically",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080/api/v1" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" },
    { "key": "branch_id", "value": "" },
    { "key": "warehouse_id", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "product_id", "value": "" },
    { "key": "item_id", "value": "" },
    { "key": "transfer_id", "value": "" },
    { "key": "maintenance_id", "value": "" },
    { "key": "supplier_id", "value": "" },
    { "key": "po_id", "value": "" },
    { "key": "user_id", "value": "" },
    { "key": "role_id", "value": "" },
    { "key": "disposal_id", "value": "" },
    { "key": "tag_id", "value": "" },
    { "key": "alert_rule_id", "value": "" },
    { "key": "notification_id", "value": "" }
  ],
  "item": [
    {
      "name": "01. Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "    console.log('Tokens saved successfully');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@wolf.com\",\n  \"password\": \"Changeme1!\"\n}"
            },
            "description": "Login with email and password. Returns access + refresh tokens.\n\nThe test script automatically saves tokens to collection variables.\n\nDefault admin: admin@wolf.com / Changeme1!"
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.success && json.data) {",
                  "    pm.collectionVariables.set('access_token', json.data.access_token);",
                  "    pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{base_url}}/auth/refresh",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "description": "Refresh the access token using the refresh token. Returns new token pair (rotation)."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{base_url}}/auth/logout",
            "description": "Invalidates the refresh token server-side."
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "description": "Get current logged-in user profile, role, and permissions."
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/auth/me",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Ahmed Admin\",\n  \"phone\": \"+964770123456\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/auth/change-password",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"Changeme1!\",\n  \"new_password\": \"NewPass123!\"\n}"
            }
          }
        }
      ]
    },
